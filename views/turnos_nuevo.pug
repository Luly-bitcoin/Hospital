extends layout

block content
  h1 Nuevo Turno
  .container
    //- Sección de búsqueda del paciente
    .card
      h2 Buscar Paciente
      form#buscarPacienteForm
        .form-group
          label(for="dni") DNI del Paciente
          input#dni(type="number" required placeholder="Ingrese DNI del paciente")
        button#btnBuscar(type="button") Buscar

      //- Mensaje de error o info
      div#mensajePaciente(style="margin-top:10px; color:red; font-weight:bold;")
        div#mensajePaciente(style="margin-top:10px; font-weight:bold;")

    //- Sección de asignación de turno
    .card(style="margin-top:20px;")
      h2 Datos del Turno
      form#turnoForm
        .form-group
          label(for="medico") Médico
          select#medico
            option(value="") Seleccione
            each medico in medicos
              option(value=medico.id_medico)= medico.apellido + ", " + medico.nombre + " (" + medico.especialidad + ")"
        .form-group
          label(for="fecha") Fecha y Hora
          input#fecha(type="datetime-local" required)
        .form-group
          label(for="motivo") Motivo
          textarea#motivo(rows="4" placeholder="Motivo de la consulta")
        button(type="submit" class="btn-guardar") Guardar

    a(href="/turnos" class="btn-volver") ← Volver a Turnos

  script(defer src="/js/turnos_nuevo.js")
