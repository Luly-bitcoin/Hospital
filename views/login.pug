doctype html
html(lang="es")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title HIS Hospital

        link(rel="stylesheet" href="/css/login.css")

    body

        .contenedor

            .login-card

                .logo
                    img(src="/img/logo.png" alt="Logo Hospital")

                h1 HIS Hospital

                form(action="/login" method="POST")

                    .grupo
                        label Usuario
                        input(
                            type="text"
                            name="usuario"
                            placeholder="Ingrese su usuario"
                            required
                        )

                    .grupo
                        label Contraseña
                        input(
                            type="password"
                            name="password"
                            placeholder="Ingrese su contraseña"
                            required
                        )

                    button.btn-login(type="submit")
                        | Ingresar

                a.btn-registro(href="/register")
                    | Registrarme