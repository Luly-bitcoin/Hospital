doctype html
html
    head
        title Nuevo Paciente

    body

        h1 Nuevo Paciente

        form(action="/pacientes/nuevo" method="POST")

            input(
                type="number"
                name="dni"
                placeholder="DNI"
                required
            )

            br
            br

            input(
                type="text"
                name="nombre"
                placeholder="Nombre"
                required
            )

            br
            br

            input(
                type="text"
                name="apellido"
                placeholder="Apellido"
                required
            )

            br
            br

            select(name="sexo")
                option(value="M") Masculino
                option(value="F") Femenino

            br
            br

            input(
                type="date"
                name="fecha_nacimiento"
            )

            br
            br

            input(
                type="text"
                name="telefono"
                placeholder="Telefono"
            )

            br
            br

            input(
                type="text"
                name="localidad"
                placeholder="Localidad"
            )

            br
            br

            button(type="submit")
                | Guardar