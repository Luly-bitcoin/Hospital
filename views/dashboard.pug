doctype html
html(lang="es")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title HIS Dashboard

        link(rel="stylesheet" href="/css/hospital.css")

    body

        header.header

            .logo
                a(href="/dashboard")
                    img(src="/img/logo.png")

            .header-center

                .titulo
                    h1 Hospital Information System

                nav.menu

                    if rol != 5
                        a(href="/pacientes") Pacientes

                    a(href="/camas") Camas

                    if rol == 1 || rol == 4
                        a(href="/admisiones") Admisiones

                    if rol == 1 || rol == 2
                        a(href="/enfermeria") Enfermería

                    if rol == 1 || rol == 3
                        a(href="/medico") A medicar

                    if rol == 1 || rol == 2 || rol == 3
                        a(href="/historial") Historial Clínico

                    if rol != 5
                        a(href="/turnos") Turnos

                    if rol != 5
                        a(href="/medicos") Médicos

                    if rol == 1 || rol == 2 || rol == 3
                        a(href="/altas") Dar Alta

            .usuario
                a(href="/perfil")
                    img(src="/img/user.png")

                span= usuario

        main.dashboard

            .estadisticas

                .card
                    h3 Internados
                    p= internados

                .card
                    h3 Camas Libres
                    p= libres

                .card
                    h3 Camas Ocupadas
                    p= ocupadas

                .card
                    h3 Higienizando
                    p= higienizando

                .card
                    h3 Altas Hoy
                    p= altasHoy

            .hero

                .imagen
                    img(src="/img/hospital1.jpg")

                .imagen.centro
                    img(src="/img/hospital2.jpg")

                    
                    if rol != 5
                        a.btn.btn-danger.btn-large.btn-circle.btn-emergencia(href="/emergencias")
                            | EMERGENCIA

                .imagen
                    img(src="/img/hospital3.jpg")

        footer.footer
            p © 2026 HIS Hospital - Todos los derechos reservados