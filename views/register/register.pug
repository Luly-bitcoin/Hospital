doctype html
html(lang="es")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title Registro HIS

        link(rel="stylesheet" href="/css/style.css")
        link(rel="stylesheet", href="/css/login.css")

    body

        .contenedor

            .registro-card

                .logo
                    img(src="/img/logo.png" alt="Logo")

                h1 Registro de Personal

                p.subtitulo
                    | Crear una nueva cuenta en HIS Hospital

                if(error)
                    p.mensaje-error= error

                form(action="/registro" method="POST")

                    .fila

                        .grupo
                            label Nombre

                            input(
                                type="text"
                                name="nombre"
                                placeholder="Ingrese nombre"
                                required
                            )

                        .grupo
                            label Apellido

                            input(
                                type="text"
                                name="apellido"
                                placeholder="Ingrese apellido"
                                required
                            )

                    .fila

                        .grupo
                            label DNI

                            input(
                                type="text"
                                name="dni"
                                placeholder="Ingrese DNI"
                                required
                            )

                        .grupo
                            label Matrícula

                            input(
                                type="text"
                                name="matricula"
                                placeholder="Matrícula profesional"
                            )

                    

                    .grupo

                        label Correo Electrónico

                        input(
                            type="email"
                            name="email"
                            placeholder="correo@hospital.com"
                            required
                        )

                    .grupo

                        label Usuario

                        input(
                            type="text"
                            name="usuario"
                            placeholder="Nombre de usuario"
                            required
                        )

                    .fila

                        .grupo

                            label Contraseña

                            input(
                                type="password"
                                name="password"
                                placeholder="********"
                                required
                            )

                        .grupo

                            label Confirmar Contraseña

                            input(
                                type="password"
                                name="confirmPassword"
                                placeholder="********"
                                required
                            )

                    .grupo

                        label Rol

                        select(
                            name="rol"
                            id="rol"
                            required
                        )

                            option(value="")
                                | Seleccionar

                            option(value="ADMIN")
                                | Administrador

                            option(value="ADMISION")
                                | Admisión

                            option(value="ENFERMERIA")
                                | Enfermería

                            option(value="MEDICO")
                                | Médico

                            option(value="LIMPIEZA")
                                | Limpieza
                    
                    #grupoDatosMedico(style="display:none;")

                        .grupo
                            label Especialidad

                            input(
                                type="text"
                                name="especialidad"
                                placeholder="Ej: Cardiología"
                            )

                        .grupo
                            label Sexo

                            select(name="sexo")
                                option(value="") Seleccionar
                                option(value="M") Masculino
                                option(value="F") Femenino

                        .grupo
                            label Fecha de nacimiento

                            input(
                                type="date"
                                name="fecha_nacimiento"
                            )

                        .grupo
                            label Teléfono

                            input(
                                type="text"
                                name="telefono"
                                placeholder="Ingrese teléfono"
                            )

                    .grupo

                        label Código del Rol

                        input(
                            type="password"
                            name="codigoRol"
                            placeholder="Ingrese código del rol"
                            required
                        )

                    button.btn.btn-full.btn-success(type="submit")
                        | Registrar Usuario

                a.btn.btn-full.btn-primary(href="/")
                    | Volver al Login

        script(src="/js/register.js")