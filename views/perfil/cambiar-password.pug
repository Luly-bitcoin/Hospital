doctype html
html(lang="es")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")

        title Cambiar Contraseña

        link(
            rel="stylesheet"
            href="/css/perfil.css"
        )

    body

        .perfil-card

            h1 Cambiar Contraseña

            if(error)
                .error= error

            if(success)
                .success= success

            form(
                action="/perfil/cambiar-password"
                method="POST"
            )

                .grupo
                    label Contraseña Actual

                    input(
                        type="password"
                        name="passwordActual"
                        required
                    )

                .grupo
                    label Nueva Contraseña

                    input(
                        type="password"
                        name="passwordNueva"
                        required
                    )

                .grupo
                    label Confirmar Nueva Contraseña

                    input(
                        type="password"
                        name="confirmPassword"
                        required
                    )

                .acciones

                    button.btn-principal(
                        type="submit"
                    )
                        | Guardar Cambios

                    a.btn-volver(
                        href="/perfil"
                    )
                        | Cancelar