doctype html
html(lang="es")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")

        title Mi Perfil

        link(
            rel="stylesheet"
            href="/css/hospital.css"
        )

    body(style="display:flex; justify-content:center; align-items:center; padding:40px;")
    

        .perfil-card

            .logo-perfil
                img(
                    src="/img/user.png"
                    alt="User"
                )

            .usuario-perfil
                = usuario.usuario

            if(error)
                .mensaje-error= error

            form(
                action="/perfil/editar"
                method="POST"
                id="formPerfil"
            )

                .datos-grid

                    .grupo
                        label Nombre

                        input.editable(
                            type="text"
                            name="nombre"
                            value=usuario.nombre
                            readonly
                        )

                    .grupo
                        label Apellido

                        input.editable(
                            type="text"
                            name="apellido"
                            value=usuario.apellido
                            readonly
                        )

                    .grupo
                        label DNI

                        input(
                            type="text"
                            value=usuario.dni
                            readonly
                        )

                    .grupo
                        label Matrícula

                        if usuario.matricula
                            input(
                                type="text"
                                value=usuario.matricula
                                readonly
                            )
                        else
                            input(
                                type="text"
                                value="No registrada"
                                readonly
                            )

                    .grupo
                        label Correo

                        input.editable(
                            type="email"
                            name="email"
                            value=usuario.email
                            readonly
                        )

                    .grupo
                        label Rol

                        input(
                            type="text"
                            value=usuario.rol
                            readonly
                        )

                    .grupo
                        label Contraseña

                        input(
                            type="password"
                            value="********"
                            readonly
                        )

                .acciones

                    button.btn.btn-full.btn-primary(
                        type="button"
                        id="btnEditar"
                    )
                        | Editar Perfil

                    a.btn.btn-full.btn-primary(
                        href="/perfil/cambiar-password"
                    )
                        | Cambiar Contraseña

                    a.btn.btn-full.btn-success(
                        href="/perfil/cambiar-rol"
                    )
                        | Cambiar Rol

                    a.btn.btn-full.btn-secondary(
                        href="/dashboard"
                    )
                        | Volver al Inicio

                    a.btn.btn-full.btn-danger(
                        href="#"
                        onclick="confirmarLogout()"
                    )
                        | Cerrar Sesión

            script(src="/js/perfil.js")